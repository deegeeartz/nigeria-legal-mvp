# PostgreSQL runtime configuration
ENVIRONMENT=development
STRICT_SECURITY_MODE=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nigeria_legal_mvp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nigeria_legal_mvp
PAYSTACK_SECRET_KEY=dev_paystack_secret
PAYSTACK_WEBHOOK_ENFORCE_SIGNATURE=true
SEAL_ENCRYPTION_KEY=

# Storage
APP_UPLOADS_DIR=C:\Users\PC\Desktop\nigeria-legal-mvp\storage\uploads

# Auth/session settings
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_HASH_ITERATIONS=260000

# Auth abuse protection
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_FAILURE_LIMIT=5
REFRESH_FAILURE_LIMIT=8
RATE_LIMIT_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# Upload security
MALWARE_SCAN_MODE=eicar
MALWARE_SCAN_FAIL_CLOSED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=5

# Observability
LOG_LEVEL=INFO
SLOW_REQUEST_MS=800
ENABLE_REQUEST_LOGGING=true
